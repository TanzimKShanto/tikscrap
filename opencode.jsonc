{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-9b49976f-6446-4b9e-aaa0-fd2430539d74"
      }
    },
    "filesystem": {
      "type": "local",
      "command": [
        "pnpm",
        "dlx",
        "@modelcontextprotocol/server-filesystem",
        "/home/tanxim/projects/tikscrap"
      ],
      "enabled": true
    }
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "edit": "ask",
    "write": "ask"
  }
}
